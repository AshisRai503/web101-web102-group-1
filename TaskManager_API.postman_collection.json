{
  "info": {
    "name": "PERN Task Manager API",
    "description": "API documentation for the PERN Stack Task Manager web application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "pern-task-manager-api-collection"
  },
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "1. Signup",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"inviteToken\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/signup",
              "host": ["{{base_url}}"],
              "path": ["auth", "signup"]
            },
            "description": "Register a new user account. Requires an admin invite token."
          }
        },
        {
          "name": "2. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.environment.set('token', res.data.token);",
                  "  console.log('Token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate and receive a JWT. The Tests script auto-saves the token to the environment variable."
          }
        }
      ],
      "description": "Authentication endpoints — no JWT required."
    },
    {
      "name": "USERS",
      "item": [
        {
          "name": "3. Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users/me",
              "host": ["{{base_url}}"],
              "path": ["users", "me"]
            },
            "description": "Get the authenticated user's own profile."
          }
        },
        {
          "name": "4. List All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/users",
              "host": ["{{base_url}}"],
              "path": ["users"]
            },
            "description": "List all registered users. Admin only."
          }
        },
        {
          "name": "5. Upload Avatar",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "type": "file",
                  "src": "",
                  "description": "Select an image file to upload as your avatar"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/users/me/avatar",
              "host": ["{{base_url}}"],
              "path": ["users", "me", "avatar"]
            },
            "description": "Upload or replace the authenticated user's avatar image."
          }
        }
      ],
      "description": "User management endpoints — JWT required for all."
    },
    {
      "name": "TASKS",
      "item": [
        {
          "name": "6. List Tasks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            },
            "description": "List all tasks for the authenticated user."
          }
        },
        {
          "name": "7. Create Task",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Task\",\n  \"description\": \"A test\",\n  \"priority\": \"medium\",\n  \"status\": \"pending\",\n  \"due_date\": \"2026-06-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["tasks"]
            },
            "description": "Create a new task."
          }
        },
        {
          "name": "8. Get Task by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/:id",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id"],
              "variable": [
                { "key": "id", "value": "1", "description": "Task primary key" }
              ]
            },
            "description": "Fetch a single task by its ID."
          }
        },
        {
          "name": "9. Update Task",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"priority\": \"high\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/:id",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id"],
              "variable": [
                { "key": "id", "value": "1", "description": "Task primary key" }
              ]
            },
            "description": "Full or partial update of a task."
          }
        },
        {
          "name": "10. Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/:id",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id"],
              "variable": [
                { "key": "id", "value": "1", "description": "Task primary key" }
              ]
            },
            "description": "Permanently remove a task."
          }
        },
        {
          "name": "11. Update Task Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/:id/status",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id", "status"],
              "variable": [
                { "key": "id", "value": "1", "description": "Task primary key" }
              ]
            },
            "description": "Update only the status field of a task."
          }
        }
      ],
      "description": "Task management endpoints — JWT required for all."
    },
    {
      "name": "CHECKLISTS",
      "item": [
        {
          "name": "12. Get Checklists for Task",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/:id/checklists",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id", "checklists"],
              "variable": [
                { "key": "id", "value": "1", "description": "Parent task primary key" }
              ]
            },
            "description": "List all checklist items for a task."
          }
        },
        {
          "name": "13. Create Checklist Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Checklist item 1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/:id/checklists",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id", "checklists"],
              "variable": [
                { "key": "id", "value": "1", "description": "Parent task primary key" }
              ]
            },
            "description": "Create a new checklist item for a task."
          }
        },
        {
          "name": "14. Update Checklist Item",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"completed\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/tasks/:id/checklists/:checklist_id",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id", "checklists", ":checklist_id"],
              "variable": [
                { "key": "id", "value": "1", "description": "Parent task primary key" },
                { "key": "checklist_id", "value": "1", "description": "Checklist item primary key" }
              ]
            },
            "description": "Update a specific checklist item (e.g. mark as completed)."
          }
        },
        {
          "name": "15. Delete Checklist Item",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/:id/checklists/:checklist_id",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id", "checklists", ":checklist_id"],
              "variable": [
                { "key": "id", "value": "1", "description": "Parent task primary key" },
                { "key": "checklist_id", "value": "1", "description": "Checklist item primary key" }
              ]
            },
            "description": "Remove a specific checklist item from a task."
          }
        }
      ],
      "description": "Checklist management endpoints — JWT required for all."
    },
    {
      "name": "ATTACHMENTS",
      "item": [
        {
          "name": "16. Get Attachments for Task",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/tasks/:id/attachments",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id", "attachments"],
              "variable": [
                { "key": "id", "value": "1", "description": "Parent task primary key" }
              ]
            },
            "description": "List all attachments for a task."
          }
        },
        {
          "name": "17. Upload Attachment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select any file to upload as an attachment"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/tasks/:id/attachments",
              "host": ["{{base_url}}"],
              "path": ["tasks", ":id", "attachments"],
              "variable": [
                { "key": "id", "value": "1", "description": "Parent task primary key" }
              ]
            },
            "description": "Upload a file attachment to a task."
          }
        }
      ],
      "description": "Attachment management endpoints — JWT required for all."
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api/v1",
      "description": "Base URL for all API requests"
    },
    {
      "key": "token",
      "value": "",
      "description": "JWT token — auto-filled after running the Login request"
    }
  ]
}